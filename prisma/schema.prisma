generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String
  price         Int
  category      String
  team          String
  contents      String?
  benefits      String?
  itemsCommands String
  imageUrl      String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String
  minecraftNickname  String              @unique
  contact            String?
  balance            Int                 @default(0)
  role               String              @default("user")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  orders             Order[]
  currencyTopUps     CurrencyTopUp[]
  walletTransactions WalletTransaction[]
}

model Order {
  id                 String              @id @default(cuid())
  userId             String?
  playerNickname     String
  contact            String
  email              String?
  products           String
  totalAmount        Int
  status             String              @default("pending")
  paymentMethod      String              @default("wallet")
  monoInvoiceId      String?             @unique
  monoPaymentUrl     String?
  createdAt          DateTime            @default(now())
  paidAt             DateTime?
  issuedAt           DateTime?
  user               User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  walletTransactions WalletTransaction[]
}

model CurrencyTopUp {
  id                 String              @id @default(cuid())
  userId             String
  packageId          String
  amountTalers       Int
  amountKopiyky      Int
  status             String              @default("pending")
  monoInvoiceId      String?             @unique
  monoPaymentUrl     String?
  createdAt          DateTime            @default(now())
  paidAt             DateTime?
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletTransactions WalletTransaction[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model WalletTransaction {
  id           String         @id @default(cuid())
  userId       String
  type         String
  amount       Int
  balanceAfter Int
  description  String
  adminNote    String?
  orderId      String?
  topUpId      String?
  createdAt    DateTime       @default(now())
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  order        Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  topUp        CurrencyTopUp? @relation(fields: [topUpId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([orderId])
  @@index([topUpId])
}

model StoreSetting {
  id           String   @id @default("global")
  streamActive Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
