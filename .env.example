DATABASE_URL="file:./dev.db"
APP_URL="http://localhost:3000"

# Put the real monobank acquiring token only here on the server.
MONOBANK_TOKEN="your_token_here"

# Optional placeholder if you later switch to jar-based payments.
MONOBANK_JAR_ID="your_jar_id_here"

# Optional. If empty, the app fetches and caches the merchant public key.
MONOBANK_PUBLIC_KEY=""

# Local-only balance top-up simulator. Set to "false" for real monobank invoices.
MONOBANK_MOCK_MODE="true"

# Local-only webhook testing helper. Keep "false" in production.
MONOBANK_SKIP_WEBHOOK_SIGNATURE="false"

ADMIN_PASSWORD="your_password_here"
ADMIN_SESSION_SECRET="replace-with-a-long-random-string"
USER_SESSION_SECRET="replace-with-another-long-random-string"
