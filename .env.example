# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://postgres.xhzhqtdjehheokmwhlxd:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://postgres.xhzhqtdjehheokmwhlxd:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"
APP_URL="http://localhost:3000"

# Put the real monobank acquiring token only here on the server.
MONOBANK_TOKEN="your_token_here"

# Optional placeholder if you later switch to jar-based payments.
MONOBANK_JAR_ID="your_jar_id_here"

# Optional. If empty, the app fetches and caches the merchant public key.
MONOBANK_PUBLIC_KEY=""

# Local-only balance top-up simulator. Set to "false" for real monobank invoices.
MONOBANK_MOCK_MODE="true"

# Local-only webhook testing helper. Keep "false" in production.
MONOBANK_SKIP_WEBHOOK_SIGNATURE="false"

# Optional jar-based top-ups. Set MONOBANK_JAR_MODE="true" to use a monobank jar
# instead of merchant invoices for balance top-ups.
MONOBANK_JAR_MODE="false"
MONOBANK_JAR_SEND_ID="96kW9kgsNS"
MONOBANK_JAR_ACCOUNT_ID=""
MONOBANK_PERSONAL_TOKEN=""
MONOBANK_PERSONAL_WEBHOOK_SECRET="replace-with-a-long-random-string"

# SMTP for registration email verification. In local dev, if SMTP_HOST/SMTP_FROM are empty,
# the verification code is printed in the Next.js server console instead of sending an email.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Zombie Event Shop <no-reply@example.com>"
EMAIL_VERIFICATION_SECRET="replace-with-a-long-random-string"

ADMIN_PASSWORD="your_password_here"
ADMIN_SESSION_SECRET="replace-with-a-long-random-string"
USER_SESSION_SECRET="replace-with-another-long-random-string"
