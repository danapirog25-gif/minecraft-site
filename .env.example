# Connect to Supabase via connection pooling.
DATABASE_URL="postgresql://postgres.project-ref:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for Prisma schema pushes/migrations.
DIRECT_URL="postgresql://postgres.project-ref:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

APP_URL="https://your-domain.example"

# Merchant acquiring mode. Leave empty if you only use jar payments.
MONOBANK_TOKEN=""
MONOBANK_PUBLIC_KEY=""
MONOBANK_MOCK_MODE="false"
MONOBANK_SKIP_WEBHOOK_SIGNATURE="false"

# Jar-based top-ups. Users must start a top-up on the site and put the generated
# ZES-... code into the monobank payment comment.
MONOBANK_JAR_MODE="true"
MONOBANK_JAR_SEND_ID="your_send_monobank_jar_id"
MONOBANK_JAR_ACCOUNT_ID=""
MONOBANK_PERSONAL_TOKEN="your_personal_monobank_api_token"
MONOBANK_PERSONAL_WEBHOOK_SECRET="replace-with-a-long-random-string"

ADMIN_PASSWORD="your_admin_password_here"
ADMIN_SESSION_SECRET="replace-with-a-long-random-string"
USER_SESSION_SECRET="replace-with-another-long-random-string"
EMAIL_VERIFICATION_SECRET="replace-with-a-third-long-random-string"

# SMTP for registration email verification. In local dev, if SMTP_HOST/SMTP_FROM
# are empty, the verification code is printed in the Next.js server console.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="Zombie Event Shop <no-reply@example.com>"

NEXT_PUBLIC_EVENT_START_AT=""
NEXT_PUBLIC_MINECRAFT_SERVER=""
NEXT_PUBLIC_STREAM_URL=""
NEXT_PUBLIC_DISCORD_URL=""
NEXT_PUBLIC_TELEGRAM_URL=""
NEXT_PUBLIC_SUPPORT_EMAIL="support@example.com"

DISCORD_WEBHOOK_URL=""
ORDER_WEBHOOK_URL=""
